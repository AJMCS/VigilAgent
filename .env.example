# ── Local LLM (Ollama) ─────────────────────────────────────────────────────────
# Run the model first: ollama pull nemotron-super
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
PRIMARY_MODEL=nemotron-3-super
SUBAGENT_MODEL=nemotron-mini

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Sandbox paths ──────────────────────────────────────────────────────────────
# On GX10/Linux keep these as-is. On macOS dev change to local paths.
REPOS_DIR=/root/vigilagent/repos
REPORTS_DIR=/root/vigilagent/reports

# ── Hardware target ────────────────────────────────────────────────────────────
HARDWARE_TARGET=dev        # dev | ascent_gx10
GPU_DEVICE=0

# ── FastAPI ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Autonomous PR monitoring ───────────────────────────────────────────────────
# How often (seconds) to poll watched repos for new PRs. Default = 5 minutes.
POLL_INTERVAL_SECONDS=300
