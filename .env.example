# Nemotron / NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
PRIMARY_MODEL=nvidia/nemotron-3-super-120b-a12b
SUBAGENT_MODEL=nvidia/nemotron-3-nano-30b-a3b

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Sandbox paths (do not change — matches NemoClaw policy)
REPOS_DIR=/root/vigilagent/repos
REPORTS_DIR=/root/vigilagent/reports

# Hardware target (switch values when deploying to ASUS Ascent GX10)
HARDWARE_TARGET=dev        # dev | ascent_gx10
GPU_DEVICE=0

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
