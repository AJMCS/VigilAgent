# ── Local LLM (Ollama) ─────────────────────────────────────────────────────────
# Run the model first: ollama pull nemotron3-nano:30b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
PRIMARY_MODEL=nemotron3-nano:30b
SUBAGENT_MODEL=nemotron3-nano:30b

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Sandbox paths ──────────────────────────────────────────────────────────────
# Defaults to <project-root>/repos and <project-root>/reports (works on all OSes).
# Uncomment and set absolute paths only if you need a custom location.
# REPOS_DIR=C:\vigilagent\repos
# REPORTS_DIR=C:\vigilagent\reports

# ── Hardware target ────────────────────────────────────────────────────────────
HARDWARE_TARGET=dev        # dev | ascent_gx10
GPU_DEVICE=0

# ── FastAPI ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Autonomous PR monitoring ───────────────────────────────────────────────────
# How often (seconds) to poll watched repos for new PRs. Default = 5 minutes.
POLL_INTERVAL_SECONDS=300
